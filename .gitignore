### VS Code ###
.vscode/

# Local secrets — never commit any real env file (only .env.example is tracked)
.env
.env.*
!.env.example
deploy/mongo-keyfile
deploy/mongo-keyfile.*
# Firebase / Google service-account credentials (FCM push, Fastlane Play deploy)
**/service-account*.json
**/firebase-service-account*.json

# Generated X.509 PKI (certs, keys, keystores) — never commit private keys
deploy/x509/dev/
deploy/x509/prod/
deploy/x509/bear/
!deploy/x509/*.sh

# macOS Finder metadata files
.DS_Store

# bear
docker-compose.bear.yml
bin/main/application-dev.yml
bin/main/application-prod.yml
bin/main/application.yml
bin/main/messages_de.properties
bin/main/messages.properties
bin/*

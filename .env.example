# ===== Hinata Server configuration =====
# Copy to .env and adjust. Every value can also be set as a plain
# environment variable on the container.

# Active Spring profile: dev (local TLS/X.509 standalone) or prod (replica set).
SPRING_PROFILES_ACTIVE=prod

# Public base URL of this server (used in JWT issuer and SSO redirects)
HINATA_BASE_URL=https://api.track.asta.hn
# Frontend (Flutter web) base URL — email deep links point here (blank ⇒ base URL)
HINATA_WEB_BASE_URL=https://track.asta.hn

# ----- Container image tags (pulled from ghcr.io/hinata-platform) -----
HINATA_SERVER_TAG=latest
HINATA_APP_TAG=latest

# HS512 JWT secret - MUST be random and at least 64 characters.
# Generate with: openssl rand -base64 64 | tr -d '\n'
HINATA_JWT_SECRET=

# ----- MongoDB (PROD: replica set, TLS + X.509 client auth) -----
# SCRAM root account (internal/admin); the app itself uses X.509, not a password.
MONGO_ROOT_USERNAME=hinata
MONGO_ROOT_PASSWORD=hinata-dev-secret
# Generate the PKI:  ./deploy/x509/generate-certs.sh prod
# then register the user: ./deploy/x509/init-prod-user.sh
# The connection string (X.509, no password) is set in docker-compose.yml.
HINATA_MONGO_TLS_KEYSTORE_PASSWORD=changeit
HINATA_MONGO_TLS_TRUSTSTORE_PASSWORD=changeit

# CIDRs of reverse proxies allowed to set X-Forwarded-For (e.g. 127.0.0.1/32 for
# a local ngrok agent, or your load-balancer subnet). Empty = trust none.
HINATA_TRUSTED_PROXIES=

# ----- SMTP (real relay in production; Mailpit is dev-only via compose.dev) -----
# Deep-link emails (issue assignment etc.) are only delivered with a real relay.
HINATA_SMTP_HOST=smtp.example.org
HINATA_SMTP_PORT=587
HINATA_SMTP_USERNAME=
HINATA_SMTP_PASSWORD=
HINATA_SMTP_AUTH=true
HINATA_SMTP_STARTTLS=true
HINATA_MAIL_FROM=mailer@asta.hn

# ----- Object storage -----
# "local-storage" runs the bundled MinIO container. To use an external object
# store instead, set COMPOSE_PROFILES= (empty) and configure a provider below;
# the MINIO_ROOT_* credentials are then no longer needed.
COMPOSE_PROFILES=local-storage

# Provider: s3 (default — MinIO, AWS S3, Google Cloud Storage, Cloudflare R2,
# DigitalOcean Spaces, any S3-compatible store) or azure (Azure Blob Storage).
HINATA_STORAGE_PROVIDER=s3

# --- Bundled MinIO (only with COMPOSE_PROFILES=local-storage) ---
MINIO_ROOT_USER=hinata
MINIO_ROOT_PASSWORD=hinata-dev-secret

# Bucket (S3) / container (Azure) name; created automatically on first upload.
HINATA_S3_BUCKET=hinata

# --- External S3-compatible store (provider=s3) ---
# Leave commented for the bundled MinIO (the compose file targets it directly).
#
# AWS S3:
#   HINATA_S3_ENDPOINT=https://s3.eu-central-1.amazonaws.com
#   HINATA_S3_REGION=eu-central-1
#   HINATA_S3_ACCESS_KEY=<IAM access key id>
#   HINATA_S3_SECRET_KEY=<IAM secret access key>
#
# Google Cloud Storage (S3-interoperable XML API — create HMAC keys under
# Cloud Storage → Settings → Interoperability):
#   HINATA_S3_ENDPOINT=https://storage.googleapis.com
#   HINATA_S3_REGION=auto
#   HINATA_S3_ACCESS_KEY=<HMAC access id>
#   HINATA_S3_SECRET_KEY=<HMAC secret>
#   HINATA_S3_ADDRESSING_STYLE=path
#
# Cloudflare R2 / DigitalOcean Spaces / Hetzner etc.: endpoint + keys from the
# provider's dashboard, region as documented by the provider.
#
# URL addressing style: auto (recommended), virtual-host, or path.
#HINATA_S3_ADDRESSING_STYLE=auto

# --- Azure Blob Storage (provider=azure) ---
# Connection string from the storage account's "Access keys" blade (an
# account-key connection string is required — presigned downloads use SAS).
# HINATA_S3_BUCKET above is used as the blob container name.
#   HINATA_STORAGE_PROVIDER=azure
#   HINATA_AZURE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net

# ----- App integration -----
# Privacy policy shown in the app (required for store releases)
HINATA_PRIVACY_POLICY_URL=https://example.org/privacy
# Minimum app version; older clients are forced to update
HINATA_APP_MIN_VERSION=1.0.0
# Comma-separated browser origins allowed for CORS (web builds). The hosted web
# app at track.asta.hn calls the API cross-origin, so it must be allowed.
HINATA_CORS_ALLOWED_ORIGINS=https://track.asta.hn
# API docs UI — disabled by default in the prod profile (avoid leaking the API
# surface). Set to true only if you intentionally want the Scalar UI exposed.
HINATA_DOCS_ENABLED=false

# ----- Push & deep links (Hinata Connect gateway) -----
# Mobile push and invite/reset universal links go through one central gateway
# that owns the published app's FCM credentials — self-hosters need NO Firebase.
# The URL is a shared constant; the server registers itself on boot. Override
# only for testing/self-hosting your own gateway.
HINATA_GATEWAY_BASE_URL=https://connect.hinata.ahmadre.com
# Optional, only if your gateway gates registration with a bootstrap secret:
# HINATA_GATEWAY_BOOTSTRAP_SECRET=

# ----- Optional: skip the in-app first-run wizard -----
HINATA_SETUP_AUTO_COMPLETE=false
HINATA_SETUP_ORGANIZATION_NAME=
HINATA_SETUP_ADMIN_EMAIL=
HINATA_SETUP_ADMIN_USERNAME=
HINATA_SETUP_ADMIN_PASSWORD=
HINATA_SETUP_ADMIN_DISPLAY_NAME=

# ----- Optional: seed a realistic English demo workspace (dev only) -----
# Idempotent; also completes first-run setup. Login: rebar / hinata-demo-2026.
# Used for clicking through the app and capturing screenshots. Never enable in prod
# (the seeder is @Profile("!prod") and is skipped there regardless of this flag).
HINATA_DEMO_SEED=true
# Reset=true wipes the workspace and re-seeds the same dataset on every boot, for
# repeatable manual/automated testing. Requires HINATA_DEMO_SEED=true.
HINATA_DEMO_RESET=false

# ----- Rate limiting / brute force -----
HINATA_RATE_LIMIT_ENABLED=true
HINATA_RATE_LIMIT_API=300
HINATA_RATE_LIMIT_AUTH=10
# Per-IP requests/minute budget for the MCP endpoint (own bucket).
HINATA_RATE_LIMIT_MCP=120
HINATA_MAX_LOGIN_FAILURES=5
HINATA_LOGIN_BLOCK_MINUTES=15

# ----- MCP (Model Context Protocol) server -----
# Lets AI clients (Claude, Cursor, …) reach a curated set of read/write tools,
# authenticated with scoped Personal Access Tokens on the /mcp endpoint. The
# same flag gates the transport, the PAT UI, and the `mcp` app feature flag.
HINATA_MCP_ENABLED=true
HINATA_MCP_SERVER_NAME=hinata
# Max active Personal Access Tokens a single user may hold.
HINATA_MCP_MAX_PATS=20
# Default PAT lifetime in days when none is given (0 = never expires).
HINATA_MCP_TOKEN_TTL_DAYS=90
# Phase-2 OAuth 2.1 authorization server (Claude/Desktop one-click Connect).
# Requires HINATA_BASE_URL to be the public HTTPS URL of this server.
HINATA_MCP_OAUTH_ENABLED=true
# Allow anonymous RFC 7591 Dynamic Client Registration (Claude needs it).
HINATA_MCP_OAUTH_DCR=true
# MCP OAuth access-token / refresh-token lifetimes.
HINATA_MCP_OAUTH_ACCESS_TTL_SECONDS=3600
HINATA_MCP_OAUTH_REFRESH_TTL_DAYS=30

# ----- Published host ports (reverse proxy on cloud.asta.hn forwards to these) -----
# api.track.asta.hn:443 → host:3356   |   track.asta.hn:443 → host:3456
HINATA_PORT=3356
HINATA_APP_PORT=3456

# CIDR of the reverse proxy so the server trusts its X-Forwarded-* headers and
# logs/limits by the real client IP. Set to the proxy's address as seen by the
# container (determined on the host during deploy), e.g. 172.16.0.0/12.
# HINATA_TRUSTED_PROXIES is defined above; set it for production.

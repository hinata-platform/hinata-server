# ===== Hivora Server configuration =====
# Copy to .env and adjust. Every value can also be set as a plain
# environment variable on the container.

# Active Spring profile: dev (local TLS/X.509 standalone) or prod (replica set).
SPRING_PROFILES_ACTIVE=prod

# Public base URL of this server (used in JWT issuer and SSO redirects)
HIVORA_BASE_URL=https://hivora.example.org

# HS512 JWT secret - MUST be random and at least 64 characters.
# Generate with: openssl rand -base64 64 | tr -d '\n'
HIVORA_JWT_SECRET=

# ----- MongoDB (PROD: replica set, TLS + X.509 client auth) -----
# SCRAM root account (internal/admin); the app itself uses X.509, not a password.
MONGO_ROOT_USERNAME=hivora
MONGO_ROOT_PASSWORD=
# Generate the PKI:  ./deploy/x509/generate-certs.sh prod
# then register the user: ./deploy/x509/init-prod-user.sh
# The connection string (X.509, no password) is set in docker-compose.yml.
HIVORA_MONGO_TLS_KEYSTORE_PASSWORD=changeit
HIVORA_MONGO_TLS_TRUSTSTORE_PASSWORD=changeit

# CIDRs of reverse proxies allowed to set X-Forwarded-For (e.g. 127.0.0.1/32 for
# a local ngrok agent, or your load-balancer subnet). Empty = trust none.
HIVORA_TRUSTED_PROXIES=

# ----- SMTP (Mailpit in dev, real relay in production) -----
HIVORA_SMTP_HOST=mailpit
HIVORA_SMTP_PORT=1025
HIVORA_SMTP_USERNAME=
HIVORA_SMTP_PASSWORD=
HIVORA_SMTP_AUTH=false
HIVORA_SMTP_STARTTLS=false
HIVORA_MAIL_FROM=hivora@example.org

# ----- S3 object storage (MinIO) -----
MINIO_ROOT_USER=hivora
MINIO_ROOT_PASSWORD=
HIVORA_S3_BUCKET=hivora

# ----- App integration -----
# Privacy policy shown in the app (required for store releases)
HIVORA_PRIVACY_POLICY_URL=https://example.org/privacy
# Minimum app version; older clients are forced to update
HIVORA_APP_MIN_VERSION=1.0.0
# Comma-separated browser origins allowed for CORS (web builds)
HIVORA_CORS_ALLOWED_ORIGINS=
# API docs UI — disabled by default in the prod profile (avoid leaking the API
# surface). Set to true only if you intentionally want the Scalar UI exposed.
HIVORA_DOCS_ENABLED=false

# ----- Optional: skip the in-app first-run wizard -----
HIVORA_SETUP_AUTO_COMPLETE=false
HIVORA_SETUP_ORGANIZATION_NAME=
HIVORA_SETUP_ADMIN_EMAIL=
HIVORA_SETUP_ADMIN_USERNAME=
HIVORA_SETUP_ADMIN_PASSWORD=
HIVORA_SETUP_ADMIN_DISPLAY_NAME=

# ----- Rate limiting / brute force -----
HIVORA_RATE_LIMIT_ENABLED=true
HIVORA_RATE_LIMIT_API=300
HIVORA_RATE_LIMIT_AUTH=10
HIVORA_MAX_LOGIN_FAILURES=5
HIVORA_LOGIN_BLOCK_MINUTES=15

# Published server port
HIVORA_PORT=8080
